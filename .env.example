PORT=5000
NODE_ENV=development
JWT_SECRET=change-me-super-secret-jwt-key-at-least-32-chars-long
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key-for-server-side-operations-only
SUPABASE_ANON_KEY=eyJ-your-anon-key
CHANNEL_TOKEN_SECRET=change-me-channel-token-secret-at-least-32-chars-long

# Meta (Facebook Developer App)
META_APP_ID=123456789
META_APP_SECRET=your_app_secret
META_GRAPH_VERSION=v19.0
META_REDIRECT_URI=http://localhost:5000/api/meta/oauth/callback
META_SCOPES=pages_show_list,pages_read_engagement,pages_manage_posts,pages_messaging,pages_manage_metadata,instagram_basic,instagram_manage_messages,instagram_content_publish
META_VERIFY_TOKEN=replace-with-random-verify-token

# Public base URL (required for Instagram publishing when using local-generated images like /generated/flyers/...)
# Example (local): http://localhost:5000
# Example (prod): https://yourdomain.com

PUBLIC_BASE_URL=http://localhost:5000

# Twilio (optional SMS Integration)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token

# App Settings
APP_NAME=LeadFlow AI
SECRET_CRYPTO_KEY=your-base64-encoded-32-byte-aes-256-key-here==
CORS_ORIGINS=http://localhost:5000
BACKGROUND_INTERVAL_MS=5000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_FLYER_MODEL=gpt-4.1-mini

# Outbound fetch timeout (Supabase/Meta/OpenAI). Increase if you see UND_ERR_CONNECT_TIMEOUT.
FETCH_TIMEOUT_MS=30000

# Redis response caching (optional)
# Set REDIS_CACHE_ENABLED=true to enable caching for authenticated GET endpoints.
REDIS_CACHE_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_CACHE_TTL_SECONDS=30
